{
	"name": "@nomercy-entertainment/nomercy-music-player",
	"version": "2.0.0-alpha.0",
	"description": "Headless, plugin-driven music player engine. HLS-ready, crossfade-capable, externally-orchestratable, leak-tested.",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"license": "Apache-2.0",
	"author": {
		"name": "NoMercy Entertainment",
		"email": "info@nomercy.tv",
		"url": "https://nomercy.tv"
	},
	"contributors": [
		"Stoney Eagle <stoney@nomercy.tv>"
	],
	"homepage": "https://github.com/NoMercy-Entertainment/nomercy-music-player",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NoMercy-Entertainment/nomercy-music-player.git"
	},
	"sideEffects": false,
	"files": [
		"dist",
		"src"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./plugins": {
			"types": "./dist/plugins/index.d.ts",
			"import": "./dist/plugins/index.js"
		},
		"./plugins/auto-advance": {
			"types": "./dist/plugins/auto-advance.d.ts",
			"import": "./dist/plugins/auto-advance.js"
		},
		"./plugins/equalizer": {
			"types": "./dist/plugins/equalizer/index.d.ts",
			"import": "./dist/plugins/equalizer/index.js"
		},
		"./plugins/spectrum": {
			"types": "./dist/plugins/spectrum.d.ts",
			"import": "./dist/plugins/spectrum.js"
		},
		"./plugins/lyrics": {
			"types": "./dist/plugins/lyrics.d.ts",
			"import": "./dist/plugins/lyrics.js"
		},
		"./plugins/visualization": {
			"types": "./dist/plugins/visualization.d.ts",
			"import": "./dist/plugins/visualization.js"
		},
		"./plugins/tab-leader": {
			"types": "./dist/plugins/tab-leader.d.ts",
			"import": "./dist/plugins/tab-leader.js"
		},
		"./plugins/media-session": {
			"types": "./dist/plugins/media-session.d.ts",
			"import": "./dist/plugins/media-session.js"
		},
		"./plugins/key-handler": {
			"types": "./dist/plugins/key-handler.d.ts",
			"import": "./dist/plugins/key-handler.js"
		},
		"./plugins/message": {
			"types": "./dist/plugins/message.d.ts",
			"import": "./dist/plugins/message.js"
		},
		"./plugins/embed": {
			"types": "./dist/plugins/embed.d.ts",
			"import": "./dist/plugins/embed.js"
		},
		"./plugins/live-transcoding": {
			"types": "./dist/plugins/live-transcoding.d.ts",
			"import": "./dist/plugins/live-transcoding.js"
		},
		"./plugins/group-listening": {
			"types": "./dist/plugins/group-listening.d.ts",
			"import": "./dist/plugins/group-listening.js"
		},
		"./plugins/drm": {
			"types": "./dist/plugins/drm.d.ts",
			"import": "./dist/plugins/drm.js"
		},
		"./plugins/cast-sender": {
			"types": "./dist/plugins/cast-sender.d.ts",
			"import": "./dist/plugins/cast-sender.js"
		},
		"./backends/audio-element": {
			"types": "./dist/backends/audio-element.d.ts",
			"import": "./dist/backends/audio-element.js"
		},
		"./backends/web-audio": {
			"types": "./dist/backends/web-audio.d.ts",
			"import": "./dist/backends/web-audio.js"
		},
		"./streams/native": {
			"types": "./dist/streams/native.d.ts",
			"import": "./dist/streams/native.js"
		},
		"./streams/hls": {
			"types": "./dist/streams/hls.d.ts",
			"import": "./dist/streams/hls.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"music",
		"player",
		"audio",
		"hls",
		"crossfade",
		"plugin",
		"NoMercy"
	],
	"dependencies": {
		"@nomercy-entertainment/nomercy-player-core": "file:../nomercy-player-kit"
	},
	"peerDependencies": {
		"audiomotion-analyzer": ">=4.5.0"
	},
	"peerDependenciesMeta": {
		"audiomotion-analyzer": {
			"optional": true
		}
	},
	"devDependencies": {
		"@antfu/eslint-config": "^4.0.0",
		"@types/node": "^22.0.0",
		"audiomotion-analyzer": "^4.5.4",
		"eslint": "^9.0.0",
		"happy-dom": "^20.8.9",
		"typescript": "^5.6.0",
		"@vitest/ui": "^4.1.5",
		"vite": "^8.0.11",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^4.1.5"
	},
	"publishConfig": {
		"access": "public"
	}
}
